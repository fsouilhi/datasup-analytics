# ============================================================
# DataSup Analytics — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs
# Ne jamais committer le fichier .env
# ============================================================

# --- PostgreSQL LOCAL ---
PG_LOCAL_HOST=localhost
PG_LOCAL_PORT=5432
PG_LOCAL_BASE=datasup
PG_LOCAL_UTILISATEUR=postgres
PG_LOCAL_MOT_DE_PASSE=votre_mot_de_passe_local

# --- Supabase (PostgreSQL cloud) ---
# Récupérer dans : Supabase > Project Settings > Database > Connection string
SUPABASE_HOST=db.xxxxxxxxxxxx.supabase.co
SUPABASE_PORT=5432
SUPABASE_BASE=postgres
SUPABASE_UTILISATEUR=postgres
SUPABASE_MOT_DE_PASSE=votre_mot_de_passe_supabase

# --- Environnement actif : "local" ou "supabase" ---
ENV_CIBLE=local
